{	auto_https off
	http_port 80
	https_port 0
}
:80 {
	# 从 X-Forwarded-Host 提取端口号
	# map source 用完整 placeholder 语法（{>X-Forwarded-Host} 可能不生效）
	map {http.request.header.X-Forwarded-Host} {upstream_port} {
		~(?i)^(\d+)-.*hermesstudio  {re.match.1}
		default                      8648
	}

	# /preview/ -> hermes-webui:8651
	handle_path /preview/* {
		reverse_proxy hermes-webui:8651 {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
		}
	}

	# /xai-oauth/ -> hermes-webui:56121
	handle_path /xai-oauth/* {
		reverse_proxy hermes-webui:56121 {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
		}
	}

	# 默认 -> hermes-webui:{upstream_port}
	handle {
		reverse_proxy hermes-webui:{upstream_port} {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
			header_up X-Forwarded-Host {http.request.header.X-Forwarded-Host}
		}
	}
}
