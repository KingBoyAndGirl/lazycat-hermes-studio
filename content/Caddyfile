{
	auto_https off
	http_port 80
	https_port 0
}
:80 {
	# 子域名端口前缀路由：(\d+)-*-hermesstudio → hermes-webui:<port>
	# 匹配 9090-1-hermesstudio.nasw.heiyu.space → hermes-webui:9090
	@port_prefix {
		header_regexp X-Forwarded-Host (?i)^(\d+)-.*hermesstudio
	}
	handle @port_prefix {
		reverse_proxy hermes-webui:{re.capture.1} {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
			header_up X-Forwarded-Host {http.request.header.X-Forwarded-Host}
		}
	}

	# /preview/ → hermes-webui:8651（剥离前缀）
	handle_path /preview/* {
		reverse_proxy hermes-webui:8651 {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
		}
	}

	# /xai-oauth/ → hermes-webui:56121（剥离前缀）
	handle_path /xai-oauth/* {
		reverse_proxy hermes-webui:56121 {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
		}
	}

	# 默认 → hermes-webui:8648
	handle {
		reverse_proxy hermes-webui:8648 {
			lb_try_duration 30s
			header_up Host {http.request.header.X-Forwarded-Host}
			header_up X-Forwarded-Host {http.request.header.X-Forwarded-Host}
		}
	}
}
